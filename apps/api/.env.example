APP_ENV=development
API_PORT=8000
APP_URL=https://www.vivacareeracademy.com
TENANT_NAME=Viva Career Academy
TENANT_DOMAIN=www.vivacareeracademy.com
ALLOW_DEMO_AUTH=false

# Required in production. Long random string (>= 32 chars) used to sign
# academy auth JWTs. Must match ACADEMY_JWT_SECRET on the frontend.
ACADEMY_JWT_SECRET=

# Required header for POST /auth/bootstrap-admin in production.
# Disable (unset) once the first admin exists.
ACADEMY_BOOTSTRAP_TOKEN=

# Comma-separated CORS allowlist. Defaults to APP_URL when unset.
CORS_ALLOWED_ORIGINS=https://www.vivacareeracademy.com
DATABASE_URL=sqlite:///./academy_os.db
REDIS_URL=redis://localhost:6379
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_HOST_EMAIL=tech@vivacareeracademy.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RESEND_API_KEY=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TEMPLATE_APPLICATION_RECEIVED=
WHATSAPP_TEMPLATE_PAYMENT_REMINDER=
WHATSAPP_TEMPLATE_CLASS_REMINDER=
