{
  "name": "viva-academy-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @academy/web",
    "build:web": "npm run build --workspace @academy/web",
    "lint:web": "npm run lint --workspace @academy/web",
    "check": "npm run lint:web && npm run build:web"
  },
  "devDependencies": {
    "turbo": "^2.0.12"
  }
}
