# Copy to .env (or export in your shell) to enable optional flows.

# --- Base configuration ---
VIVA_BASE_URL=https://www.vivacareeracademy.com
VIVA_PERF_BUDGET_MS=3000

# --- Authenticated flows (optional) ---
# Set to enable end-to-end login coverage in tests/auth.spec.ts.
VIVA_PUBLIC_USER=
VIVA_PUBLIC_PASS=
VIVA_PUBLIC_DASHBOARD=/student

VIVA_INTERNAL_USER=
VIVA_INTERNAL_PASS=
VIVA_INTERNAL_DASHBOARD=/dashboard

# --- Role-isolation contract (tests/role-isolation.spec.ts) ---
# These enforce: unpaid → no /student access; paid → own course only.
# Each scenario skips cleanly if the relevant vars aren't set.

# A student account that has NOT made payment (should be blocked from /student).
VIVA_UNPAID_USER=
VIVA_UNPAID_PASS=

# A student account that HAS paid for a specific course.
VIVA_PAID_USER=
VIVA_PAID_PASS=
# The exact path the paid student SHOULD see (their subscribed course).
VIVA_PAID_COURSE_PATH=/student/course/your-course-id
# Optional: a course they did NOT pay for (cross-course isolation check).
VIVA_PAID_FORBIDDEN_COURSE_PATH=/student/course/other-course-id

# --- Toggles ---
# 1 to fail CI on any critical issue (recommended for the release gate).
VIVA_FAIL_ON_CRITICAL=1

# 1 to skip same-origin link crawling per page (faster local runs).
VIVA_SKIP_LINKS=

# 1 to actually submit forms during tests/forms.spec.ts.
# Leave empty to render+fill but not submit (default).
VIVA_SUBMIT_FORMS=
