APP_ENV=development
APP_URL=https://www.vivacareeracademy.com
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOW_DEMO_AUTH=false

# Required in production. Long random string (>= 32 chars) used to sign
# academy auth JWTs. The Next.js server also reads this to verify the
# session cookie before rendering /admin, /admissions, /operations, etc.
ACADEMY_JWT_SECRET=

# Required header value for the one-time POST /api/v1/academy/auth/bootstrap-admin
# call that creates the first admin. Without it set, the endpoint is disabled
# in production. Rotate or unset after the first admin exists.
ACADEMY_BOOTSTRAP_TOKEN=

# Comma-separated allowlist for CORS. If unset, defaults to APP_URL.
CORS_ALLOWED_ORIGINS=https://www.vivacareeracademy.com

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/academy_os
REDIS_URL=redis://localhost:6379

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_HOST_EMAIL=tech@vivacareeracademy.com
ZOOM_DEFAULT_TIMEZONE=Asia/Kolkata

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

RESEND_API_KEY=
ACADEMY_FROM_NAME=Viva Career Academy
ACADEMY_FROM_EMAIL=support@vivacareeracademy.com
ACADEMY_REPLY_TO=support@vivacareeracademy.com

WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TEMPLATE_APPLICATION_RECEIVED=
WHATSAPP_TEMPLATE_PAYMENT_REMINDER=
WHATSAPP_TEMPLATE_CLASS_REMINDER=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
