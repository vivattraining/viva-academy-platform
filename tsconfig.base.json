{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@academy/ui": ["packages/ui/src"],
      "@academy/types": ["packages/types/src"],
      "@academy/config": ["packages/config/src"],
      "@academy/integrations": ["packages/integrations/src"]
    }
  }
}

